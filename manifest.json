{
  "manifest_version": 3,
  "name": "Rotten Ketchup",
  "version": "1.2.1",
  "description": "Adds a Censored score next to the Popcornmeter on Rotten Tomatoes movie pages.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.rottentomatoes.com/m/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png", "icons/icon48glow.png"],
      "matches": ["https://www.rottentomatoes.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@rotten-ketchup",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
